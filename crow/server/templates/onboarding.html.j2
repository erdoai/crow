{% extends "base.html.j2" %}
{% block title %}welcome — crow{% endblock %}
{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-logo">crow</h1>
        <p class="auth-subtitle">welcome! one quick thing&hellip;</p>

        <form onsubmit="submitOnboarding(); return false;">
            <label class="input-label" for="name-input">what should I call you?</label>
            <input type="text" id="name-input" class="input" placeholder="your name" autofocus>
            <button type="submit" class="btn btn-primary">get started</button>
        </form>

        <p id="auth-error" class="error hidden"></p>
    </div>
</div>
{% endblock %}
