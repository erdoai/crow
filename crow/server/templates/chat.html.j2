{% extends "base.html.j2" %}
{% block title %}chat — crow{% endblock %}
{% block body %}
<div class="chat-layout">
    <!-- Sidebar -->
    <aside class="chat-sidebar">
        <div class="sidebar-header">
            <a href="/dashboard" class="sidebar-logo">crow</a>
            <button class="btn btn-ghost btn-sm" onclick="newChat()">✏️</button>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-label">agents</div>
            <div class="agent-chips">
                {% for agent in agents %}
                <button class="agent-chip{% if agent.name == current_agent %} active{% endif %}"
                        onclick="startChatWithAgent('{{ agent.name }}')"
                        title="{{ agent.description }}">
                    {{ agent.name }}
                </button>
                {% endfor %}
            </div>
        </div>

        <div class="sidebar-section sidebar-conversations">
            <div class="sidebar-label">conversations</div>
            <div id="conversation-list">
                {% for c in conversations %}
                <a href="/chat/{{ c.id }}" class="conv-item{% if c.id == current_conversation_id %} active{% endif %}">
                    <span class="conv-thread">{{ c.gateway_thread_id }}</span>
                    <span class="conv-time">{{ c.updated_at.strftime('%b %d') if c.updated_at else '' }}</span>
                </a>
                {% endfor %}
                {% if not conversations %}
                <div class="conv-empty">no conversations yet</div>
                {% endif %}
            </div>
        </div>
    </aside>

    <!-- Chat area -->
    <main class="chat-main">
        {% if current_conversation_id %}
        <div class="chat-header">
            <span class="chat-thread-name">{{ current_thread_id }}</span>
        </div>
        <div class="chat-messages" id="messages">
            {% for msg in messages %}
            <div class="message {{ 'user' if msg.role == 'user' else 'assistant' }}">
                {% if msg.role != 'user' and msg.agent_name %}
                <div class="msg-agent">{{ msg.agent_name }}</div>
                {% endif %}
                <div class="msg-bubble">{{ msg.content }}</div>
            </div>
            {% endfor %}
            <div id="typing-indicator" class="message assistant hidden">
                <div class="msg-bubble typing">
                    <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                </div>
            </div>
        </div>
        <div class="chat-input-bar">
            <input type="text" id="chat-input" class="chat-input" placeholder="Message..."
                   onkeydown="if(event.key==='Enter'||(event.key==='Enter'&&event.metaKey))sendChatMessage()">
            <button class="chat-send-btn" onclick="sendChatMessage()">↑</button>
        </div>
        {% else %}
        <div class="chat-empty">
            <div class="chat-empty-icon">💬</div>
            <div class="chat-empty-text">select a conversation or click an agent to start chatting</div>
        </div>
        {% endif %}
    </main>
</div>

<script>
const CONVERSATION_ID = {{ current_conversation_id | tojson }};
const THREAD_ID = {{ current_thread_id | tojson }};

function scrollToBottom() {
    const el = document.getElementById('messages');
    if (el) el.scrollTop = el.scrollHeight;
}
scrollToBottom();

// SSE
if (CONVERSATION_ID) {
    const evtSource = new EventSource(`/conversations/${CONVERSATION_ID}/stream`);
    evtSource.addEventListener('message', e => {
        const data = JSON.parse(e.data);
        appendMessage(data.agent_name, data.text, false);
        document.getElementById('typing-indicator').classList.add('hidden');
    });
}

function appendMessage(agent, text, isUser) {
    const container = document.getElementById('messages');
    const typing = document.getElementById('typing-indicator');
    const div = document.createElement('div');
    div.className = `message ${isUser ? 'user' : 'assistant'}`;
    let html = '';
    if (!isUser && agent) html += `<div class="msg-agent">${agent}</div>`;
    html += `<div class="msg-bubble">${escapeHtml(text)}</div>`;
    div.innerHTML = html;
    container.insertBefore(div, typing);
    scrollToBottom();
}

function escapeHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
}

async function sendChatMessage() {
    const input = document.getElementById('chat-input');
    const text = input.value.trim();
    if (!text) return;
    input.value = '';

    appendMessage(null, text, true);
    document.getElementById('typing-indicator').classList.remove('hidden');
    scrollToBottom();

    await fetch('/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, thread_id: THREAD_ID || 'default' }),
    });
}

function startChatWithAgent(agentName) {
    const threadId = `chat-${agentName}-${Date.now()}`;
    fetch('/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            text: `Hi, I'd like to chat with you.`,
            thread_id: threadId,
            agent: agentName
        }),
    }).then(() => {
        // Poll for conversation to appear then redirect
        setTimeout(async () => {
            const res = await fetch('/conversations');
            const convs = await res.json();
            const conv = convs.find(c => c.gateway_thread_id === threadId);
            if (conv) window.location.href = `/chat/${conv.id}`;
            else window.location.href = '/chat';
        }, 1000);
    });
}

function newChat() {
    window.location.href = '/chat';
}
</script>
{% endblock %}
