{% extends "base.html.j2" %}
{% block title %}dashboard — crow{% endblock %}
{% block body %}
<div class="dashboard">
    <header class="header">
        <div class="header-left">
            <h1 class="header-logo">crow</h1>
        </div>
        <div class="header-right">
            <span class="greeting">hi, {{ display_name }}</span>
            {% if auth_enabled %}
            <form action="/auth/logout" method="post" class="inline">
                <button type="submit" class="btn btn-ghost btn-sm">sign out</button>
            </form>
            {% endif %}
        </div>
    </header>

    <main class="main">
        <!-- Agents -->
        <section class="section">
            <h2 class="section-title">agents</h2>
            <div class="card-grid">
                {% for agent in agents %}
                <div class="card">
                    <h3 class="card-title">{{ agent.name }}</h3>
                    <p class="card-desc">{{ agent.description }}</p>
                </div>
                {% endfor %}
                {% if not agents %}
                <p class="empty">no agents configured</p>
                {% endif %}
            </div>
        </section>

        {% if auth_enabled %}
        <!-- iMessage -->
        <section class="section">
            <h2 class="section-title">iMessage</h2>
            {% if phone_links %}
            <div class="list">
                {% for link in phone_links %}
                <div class="list-item">
                    <span class="mono">{{ link.phone_number }}</span>
                    <button class="btn btn-ghost btn-sm" onclick="unlinkPhone('{{ link.id }}')">remove</button>
                </div>
                {% endfor %}
            </div>
            {% endif %}
            <div class="inline-form">
                <input type="tel" id="phone-input" class="input input-sm" placeholder="+1234567890">
                <button class="btn btn-secondary btn-sm" onclick="linkPhone()">link number</button>
            </div>
        </section>
        {% endif %}

        <!-- API Keys -->
        <section class="section">
            <h2 class="section-title">API keys</h2>
            {% if api_keys %}
            <div class="list">
                {% for key in api_keys %}
                <div class="list-item">
                    <div>
                        <span class="key-name">{{ key.name }}</span>
                        <span class="mono muted">{{ key.key_prefix }}...</span>
                    </div>
                    <button class="btn btn-ghost btn-sm" onclick="deleteApiKey('{{ key.id }}')">revoke</button>
                </div>
                {% endfor %}
            </div>
            {% endif %}
            <div id="new-key-result" class="hidden key-result"></div>
            <div class="inline-form">
                <input type="text" id="key-name-input" class="input input-sm" placeholder="key name">
                <button class="btn btn-secondary btn-sm" onclick="createApiKey()">create key</button>
            </div>
        </section>

        <!-- Knowledge -->
        <section class="section">
            <h2 class="section-title">knowledge</h2>
            {% if knowledge %}
            <div class="list">
                {% for k in knowledge %}
                <div class="list-item">
                    <div>
                        <span class="badge">{{ k.category }}</span>
                        <span>{{ k.title }}</span>
                    </div>
                    <span class="muted">{{ k.agent_name }}</span>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="empty">no knowledge entries yet</p>
            {% endif %}
        </section>

        <!-- Recent Conversations -->
        <section class="section">
            <h2 class="section-title">recent conversations</h2>
            {% if conversations %}
            <div class="list">
                {% for c in conversations %}
                <div class="list-item">
                    <div>
                        <span class="badge">{{ c.gateway }}</span>
                        <span class="mono">{{ c.gateway_thread_id }}</span>
                    </div>
                    <span class="muted">{{ c.updated_at.strftime('%b %d, %H:%M') if c.updated_at else '' }}</span>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="empty">no conversations yet</p>
            {% endif %}
        </section>
    </main>
</div>
{% endblock %}
