# Database — Railway Postgres (provisioned via scaffold)
# Same DB for local dev and prod. No local Postgres needed.
CROW_DATABASE_URL=postgresql://...from-railway...

# Claude API
CROW_ANTHROPIC_API_KEY=sk-ant-...

# External systems
CROW_DEVBOT_URL=http://localhost:8484
CROW_PILOT_URL=http://localhost:9721

# iMessage gateway (local only, disabled on Railway)
CROW_IMESSAGE_ENABLED=true
CROW_IMESSAGE_ALLOWED_NUMBERS=+1234567890

# Worker auth
CROW_WORKER_API_KEY=changeme

# Embeddings
CROW_EMBEDDING_MODEL=text-embedding-3-small

# Auth (referenced from crow.yml via ${VAR} syntax)
SESSION_SECRET=change-me-to-a-random-string
RESEND_API_KEY=re_xxx
CROW_API_KEY=crow_xxx
