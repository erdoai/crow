# crow.yml — main configuration file
# Auto-imported into DB on first startup. Use `crow settings import crow.yml` to reload.
# Supports ${VAR} syntax for environment variable resolution.

# -- Agents --
# Each agent has: description, prompt template, built-in tools, MCP servers, knowledge areas.
# Prompt templates live in crow/agents/prompts/ as Jinja2 files.

agents:
  pa:
    description: "Routes inbound messages to the right specialist agent"
    prompt: pa_system.md.j2
    tools: [delegate_to_agent, knowledge_search]
    knowledge_areas: [routing, user-preferences]

  assistant:
    description: "General purpose assistant"
    prompt: assistant_system.md.j2
    tools: [knowledge_search, knowledge_write]
    mcp: [my-tools]
    knowledge_areas: [general]

  # Add more agents as needed:
  # researcher:
  #   description: "Deep research on topics"
  #   prompt: researcher_system.md.j2
  #   tools: [knowledge_search, knowledge_write]
  #   mcp: [web-search, documents]
  #   knowledge_areas: [research]

# -- MCP Servers --
# External tool providers. Crow connects via HTTP and discovers tools at runtime.
# Agents reference servers by name in their `mcp:` list.
# Headers support ${VAR} syntax for API keys.
# Add via CLI: crow mcp add my-tools http://localhost:3001/mcp

mcp: {}
  # my-tools:
  #   url: http://localhost:3001/mcp
  #
  # Example: Jina AI (web search + reader)
  # jina:
  #   url: https://mcp.jina.ai/v1
  #   headers:
  #     Authorization: "Bearer ${JINA_API_KEY}"
  #
  # Example: browser-use (web automation)
  # browser-use:
  #   url: https://api.browser-use.com/mcp
  #   headers:
  #     x-browser-use-api-key: "${BROWSERUSE_API_KEY}"

# -- Auth (optional) --
# Email-based auth with magic codes via Resend.
# Disabled by default — all endpoints are open.

# auth:
#   enabled: true
#   session_secret: ${SESSION_SECRET}
#   api_key: ${CROW_API_KEY}
#   resend:
#     api_key: ${RESEND_API_KEY}
#     from: "crow <noreply@example.com>"

# -- Built-in tools reference --
# These are always available (no MCP needed):
#   delegate_to_agent  — Route work to another agent
#   knowledge_search   — Search PARA knowledge base (semantic + keyword)
#   knowledge_write    — Save a learning to knowledge base
#   knowledge_archive  — Archive a knowledge entry
#   create_agent       — Create a new agent definition
#   list_agents        — List all agents
#   delete_agent       — Delete an agent
